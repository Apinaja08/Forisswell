# Server Configuration
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/forisswell?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Frontend URL (CORS)
CLIENT_URL=https://your-frontend-url.com

# Google Earth Engine (Forest Analysis)
GOOGLE_EARTH_ENGINE_KEY=your_google_earth_engine_key

# Sentinel Hub (Satellite Data)
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_client_secret

# Weather API
OPENWEATHER_API_KEY=your_openweather_api_key

# Google APIs (Calendar, Maps)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SENDER_EMAIL=noreply@forisswell.com
